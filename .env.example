# === 환경 분리 ===
APP_ENV=development
RENDER_DEPLOY_HOOK_STAGING=
RENDER_DEPLOY_HOOK_PRODUCTION=

MODE=APPLY
PRIMARY_LOCALE=ko
SECONDARY_LOCALE=en
FX_SOURCE=manual
FX_USDKRW=1350
FX_JPYKRW=9.0
FX_EURKRW=1470
TARGET_MARGIN_PCT=22
SHIPPING_FEE_DEFAULT=12000
FORWARDER_FEE_JPY=300
CUSTOMS_THRESHOLD_KRW=150000
CUSTOMS_RATE_DEFAULT=0.20
EMAIL_ENABLED=0
TELEGRAM_ENABLED=1

# === Docker / Gunicorn ===
PORT=8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info
APP_VERSION=dev

# Translation
TRANSLATE_PROVIDER=deepl
DEEPL_API_KEY=your-deepl-api-key-here
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Channels - Percenty
WAREHOUSE_ADDRESS=서울특별시 강남구 역삼동 123-45
RETURN_ADDRESS=서울특별시 강남구 역삼동 123-45
COUPANG_MARGIN_ADJUST=-2.0
NAVER_MARGIN_ADJUST=0.0

# Shopify
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxx
SHOPIFY_CLIENT_SECRET=shpss_xxxxx
SHOPIFY_API_VERSION=2024-07

# Channels - Shopify Markets
SHOPIFY_MARKETS_ENABLED=1

# WooCommerce
WOO_BASE_URL=https://your-woo-store.com
WOO_CK=ck_xxxxx
WOO_CS=cs_xxxxx
WOO_WEBHOOK_SECRET=your-woo-webhook-secret
WOO_API_VERSION=wc/v3

# Google
GOOGLE_SERVICE_JSON_B64=base64-encoded-service-account-json
GOOGLE_SHEET_ID=your-sheet-id

# Order Routing
ZENMARKET_ADDRESS=
WAREHOUSE_ADDRESS=서울특별시 강남구 역삼동 123-45
RETURN_ADDRESS=서울특별시 강남구 역삼동 123-45
SHOPIFY_LOCATION_ID=

# Dashboard / Monitoring
DAILY_SUMMARY_ENABLED=1
ORDERS_WORKSHEET=orders
ALERT_STALE_ORDER_DAYS=7
ALERT_FORWARDER_DAYS=5
ALERT_FX_CHANGE_PCT=3.0

# Carrier defaults
DEFAULT_DOMESTIC_CARRIER=cj
DEFAULT_INTERNATIONAL_CARRIER=ems

# Inventory Sync
INVENTORY_SYNC_ENABLED=1
STOCK_CHECK_DELAY=2
LOW_STOCK_THRESHOLD=3
PRICE_CHANGE_THRESHOLD_PCT=5.0
INVENTORY_CHECK_TIMEOUT=15

# FX Rate
FX_PROVIDER=frankfurter
FX_USE_LIVE=1
FX_CACHE_TTL=3600
FX_CHANGE_ALERT_PCT=3.0
EXCHANGERATE_API_KEY=
FX_HISTORY_WORKSHEET=fx_history
FX_RATES_WORKSHEET=fx_rates

# === Phase 7: BI + Automation ===
# Auto Pricing
AUTO_PRICING_ENABLED=1
AUTO_PRICING_MODE=DRY_RUN
MIN_MARGIN_PCT=10
MAX_PRICE_CHANGE_PCT=8

# Reorder Alerts
REORDER_CHECK_ENABLED=1
SALES_VELOCITY_DAYS=30
SAFETY_STOCK_DAYS=3
PORTER_LEAD_DAYS=7
MEMO_LEAD_DAYS=10
REORDER_SUGGESTIONS_WORKSHEET=reorder_suggestions

# New Product Detection
NEW_PRODUCT_CHECK_ENABLED=1
NEW_PRODUCT_MIN_MARGIN_PCT=15
NEW_PRODUCTS_WORKSHEET=new_product_suggestions

# Periodic Reports
WEEKLY_REPORT_ENABLED=1
MONTHLY_REPORT_ENABLED=1
WEEKLY_REPORTS_WORKSHEET=weekly_reports
MONTHLY_REPORTS_WORKSHEET=monthly_reports

# === Phase 9: Bot Commands ===
TELEGRAM_BOT_WEBHOOK_SECRET=your-webhook-secret
BOT_COMMANDS_ENABLED=1

# === Phase 9: Customer Notifications ===
CUSTOMER_NOTIFY_ENABLED=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Proxy Commerce
SMTP_FROM_EMAIL=

# === Phase 9: Auto Reorder ===
REORDER_ENABLED=0
REORDER_THRESHOLD=2
REORDER_WORKSHEET=reorder_queue
REORDER_APPROVAL_REQUIRED=1

# === Phase 9: Multi-channel Notifications ===
SLACK_WEBHOOK_URL=
SLACK_ENABLED=0
DISCORD_WEBHOOK_URL=
DISCORD_ENABLED=0

# === Phase 10: Rate Limiting ===
RATE_LIMIT_ENABLED=1
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_WEBHOOK=100/minute
RATE_LIMIT_BOT=30/minute

# === Phase 10: Request Logging ===
REQUEST_LOG_LEVEL=info
REQUEST_LOG_MASK_FIELDS=api_key,token,secret,password,authorization

# === Phase 10: Security Middleware ===
MAX_CONTENT_LENGTH=1048576
SECURITY_HSTS_ENABLED=0
CORS_ALLOWED_ORIGINS=*

# === Phase 10: Cache ===
CACHE_ENABLED=1
CACHE_MAX_SIZE=1000
CACHE_DEFAULT_TTL=300

# === Phase 10: Circuit Breaker ===
CIRCUIT_BREAKER_ENABLED=1
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# === Phase 10: Audit Log ===
AUDIT_LOG_ENABLED=1
AUDIT_WORKSHEET=audit_log

# === Phase 11: Dashboard API ===
DASHBOARD_API_ENABLED=1
DASHBOARD_API_KEY=your-dashboard-api-key
DASHBOARD_CORS_ORIGINS=*

# === Phase 11: Data Export ===
EXPORT_ENABLED=1
EXPORT_WORKSHEET=daily_exports
EXPORT_DAILY_ENABLED=1
EXPORT_WEEKLY_ENABLED=1

# === Phase 11: CLI ===
CLI_OUTPUT_FORMAT=table
CLI_COLOR_ENABLED=1

# === Plugins ===
PLUGINS_ENABLED=1
PLUGINS_AUTO_LOAD=1

# === Migration ===
MIGRATION_AUTO_CHECK=0
SCHEMA_VERSION_WORKSHEET=schema_version
MIGRATION_BACKUP_ENABLED=1

# === Profiling ===
PROFILING_ENABLED=0
PROFILING_SLOW_THRESHOLD_MS=5000
METRICS_ENABLED=1
METRICS_API_ENABLED=1

# === Config Management ===
CONFIG_HOT_RELOAD_ENABLED=0
CONFIG_CHECK_INTERVAL=60
CONFIG_STRICT_VALIDATION=0

# === Phase 14: Reviews ===
REVIEW_COLLECTION_ENABLED=0
AUTO_RESPONSE_ENABLED=0
REVIEW_NEGATIVE_THRESHOLD=2
REVIEW_SHEET_NAME=reviews

# === Phase 14: Promotions ===
PROMOTIONS_ENABLED=0
PROMO_STACK_MODE=best
PROMO_SHEET_NAME=promotions

# === Phase 14: CRM ===
CRM_ENABLED=0
CRM_LIFECYCLE_ENABLED=0
CRM_SHEET_NAME=customers
CRM_VIP_MIN_ORDERS=3
CRM_VIP_MIN_SPENT=1000000
CRM_AT_RISK_DAYS=90
CRM_DORMANT_DAYS=180
